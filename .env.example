# Connection strings — nunca commitar valores reais

# Formato legado (uma URL)
GERAL_HOMOLOGACAO_DB_URL=postgresql://postgres.xxxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# Formato recomendado (fallback pooler -> direct)
GERAL_HOMOLOGACAO_DB_URL_POOLER=postgresql://postgres.<project-ref>:SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
GERAL_HOMOLOGACAO_DB_URL_DIRECT=postgresql://postgres:SENHA@db.<project-ref>.supabase.co:5432/postgres

OUTRO_PROJETO_DB_URL=postgresql://postgres.yyyyy:SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres